# ═══════════════════════════════════════════════
# KLARA GREENHOUSE — Environment Configuration
# Copy to .env and fill in values
# ═══════════════════════════════════════════════

# Environment: development | staging | production
ENVIRONMENT=development

# Database (Railway auto-sets; leave blank for local SQLite)
DATABASE_URL=sqlite:///./klara.db

# Stripe (use test keys for beta)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=

# Admin auth
ADMIN_PASSWORD=klara-admin-2026

# SMTP for proposal email delivery
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Resend (email notifications)
RESEND_API_KEY=
NOTIFICATION_EMAIL=

# Base URL (Railway auto-sets)
BASE_URL=http://localhost:8000
